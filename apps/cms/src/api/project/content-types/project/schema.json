{
  "kind": "collectionType",
  "collectionName": "projects",
  "info": {
    "singularName": "project",
    "pluralName": "projects",
    "displayName": "Project / Case Study",
    "description": "B2B industrial steel structure case studies and project records."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "steel_grade": {
      "type": "enumeration",
      "enum": [
        "S235JR",
        "S355J2+N",
        "Inox_304L",
        "Inox_316L"
      ],
      "required": true,
      "default": "S355J2+N"
    },
    "execution_standard": {
      "type": "string",
      "required": true,
      "default": "EN 1090-2 EXC2"
    },
    "weight_tons": {
      "type": "decimal",
      "required": true
    },
    "description": {
      "type": "richtext",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "technical_specifications": {
      "type": "component",
      "repeatable": true,
      "component": "shared.technical-specification"
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    }
  }
}
