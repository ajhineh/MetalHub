    "context": "\u0648 \u0628\u0639\u062f \u0627\u0632 \u0686\u0646\u062f \u0633\u0627\u0644 \u0645\u062d\u0635\u0648\u0644 \u062a\u0628\u062f\u06cc\u0644 \u0628\u0647 \u0645\u062c\u0645\u0648\u0639\u0647\u200c\u0627\u06cc \u0627\u0632 Feature\u0647\u0627\u06cc \u0646\u0627\u0645\u0631\u062a\u0628\u0637 \u0645\u06cc\u200c\u0634\u0648\u062f.\n\u0627\u0645\u0627 \u0634\u0631\u06a9\u062a\u200c\u0647\u0627\u06cc\u06cc \u0645\u062b\u0644 Stripe\u060c GitHub\u060c Shopify \u0648 Palantir \u0627\u06cc\u0646\u06af\u0648\u0646\u0647 \u0633\u0627\u062e\u062a\u0647 \u0646\u0634\u062f\u0647\u200c\u0627\u0646\u062f.\n\u0622\u0646\u0647\u0627 \u0627\u0648\u0644 Principles \u0631\u0627 \u062a\u0639\u0631\u06cc\u0641 \u06a9\u0631\u062f\u0646\u062f.\n\u0628\u0639\u062f \u0645\u062d\u0635\u0648\u0644 \u0631\u0627.\n\u0645\u0646 \u0645\u06cc\u200c\u062e\u0648\u0627\u0647\u0645 MetalHub \u0647\u0645 \u0647\u0645\u06cc\u0646 \u0645\u0633\u06cc\u0631 \u0631\u0627 \u0637\u06cc \u06a9\u0646\u062f."
