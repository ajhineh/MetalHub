    "context": "\u0627\u06cc\u0646 \u0686\u0627\u0631\u0686\u0648\u0628 \u062a\u0636\u0645\u06cc\u0646 \u0645\u06cc\u200c\u06a9\u0646\u062f \u06a9\u0647 MetalHub \u0648\u0627\u0628\u0633\u062a\u0647 \u0628\u0647 \u0627\u0641\u0631\u0627\u062f\u060c \u0646\u0633\u0644 \u0645\u062f\u06cc\u0631\u0627\u0646 \u06cc\u0627 \u0641\u0646\u0627\u0648\u0631\u06cc\u200c\u0647\u0627\u06cc \u062e\u0627\u0635 \u0646\u0628\u0627\u0634\u062f.\n\u0628\u0631 \u0686\u0647\u0627\u0631 \u0633\u062a\u0648\u0646 \u0627\u0633\u062a\u0648\u0627\u0631 \u0627\u0633\u062a:\n\u2022\tPrinciple Continuity: \u0627\u0635\u0648\u0644 \u0627\u0632 \u0627\u0641\u0631\u0627\u062f \u0645\u0647\u0645\u200c\u062a\u0631 \u0647\u0633\u062a\u0646\u062f. \n\u2022\tKnowledge Continuity: \u062f\u0627\u0646\u0634 \u0628\u0627\u06cc\u062f \u0645\u0633\u062a\u0642\u0644 \u0627\u0632 \u062d\u0627\u0641\u0638\u0647 \u0627\u0641\u0631\u0627\u062f \u0628\u0627\u0642\u06cc \u0628\u0645\u0627\u0646\u062f. \n\u2022\tDecision Continuity: \u0645\u0646\u0637\u0642 \u062a\u0635\u0645\u06cc\u0645\u200c\u0647\u0627 \u0628\u0627\u06cc\u062f \u0628\u0631\u0627\u06cc \u0622\u06cc\u0646\u062f\u06af\u0627\u0646 \u0642\u0627\u0628\u0644 \u0641\u0647\u0645 \u0628\u0627\u0634\u062f."
