    "context": "________________________________________\n4.7 Collaboration Without Dependence\n\u0627\u06cc\u0646 \u0627\u0635\u0644 \u0631\u0627 \u0645\u06cc\u200c\u062e\u0648\u0627\u0647\u0645 \u0628\u0647\u200c\u0639\u0646\u0648\u0627\u0646 \u06cc\u06a9\u06cc \u0627\u0632 Anti-Principle\u0647\u0627\u06cc \u06a9\u0644 \u06a9\u062a\u0627\u0628 \u062b\u0628\u062a \u06a9\u0646\u06cc\u0645.\n\u0647\u0645\u06a9\u0627\u0631\u06cc \u0646\u0628\u0627\u06cc\u062f \u0648\u0627\u0628\u0633\u062a\u06af\u06cc \u0646\u0627\u0633\u0627\u0644\u0645 \u0627\u06cc\u062c\u0627\u062f \u06a9\u0646\u062f.\n\u0647\u06cc\u0686 \u0633\u0627\u0632\u0645\u0627\u0646\u06cc \u0646\u0628\u0627\u06cc\u062f \u0627\u062d\u0633\u0627\u0633 \u06a9\u0646\u062f \u0628\u062f\u0648\u0646 \u06cc\u06a9 \u0634\u0631\u06cc\u06a9 \u062e\u0627\u0635\u060c \u0642\u0627\u062f\u0631 \u0628\u0647 \u0627\u062f\u0627\u0645\u0647 \u0646\u06cc\u0633\u062a."
  },
