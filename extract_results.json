    "line": 692,
    "match": "Chapter 5 \u2013 First Principles of MetalHub",
    "context": "\u0628\u0647 \u0646\u0638\u0631 \u0645\u0646 \u0627\u06a9\u0646\u0648\u0646 \u0632\u0645\u0627\u0646 \u0645\u0639\u0631\u0641\u06cc \u0645\u062d\u0635\u0648\u0644 \u0646\u06cc\u0633\u062a\u061b \u0632\u0645\u0627\u0646 \u0645\u0639\u0631\u0641\u06cc \u0627\u0635\u0644 \u0637\u0631\u0627\u062d\u06cc \u0627\u0633\u062a.\n\u0641\u0635\u0644 \u067e\u0646\u062c\u0645 \u0631\u0627 \u0628\u0627 \u0639\u0646\u0648\u0627\u0646:\nChapter 5 \u2013 First Principles of MetalHub\n\u067e\u06cc\u0634\u0646\u0647\u0627\u062f \u0645\u06cc\u200c\u06a9\u0646\u0645.\n\u062f\u0631 \u0627\u06cc\u0646 \u0641\u0635\u0644 \u0646\u0645\u06cc\u200c\u06af\u0648\u06cc\u06cc\u0645 \u00abMetalHub \u0686\u0647 \u0642\u0627\u0628\u0644\u06cc\u062a\u200c\u0647\u0627\u06cc\u06cc \u062f\u0627\u0631\u062f\u00bb. \u0628\u0644\u06a9\u0647 \u0645\u0634\u062e\u0635 \u0645\u06cc\u200c\u06a9\u0646\u06cc\u0645 \u06a9\u0647 MetalHub \u0628\u0631 \u0627\u0633\u0627\u0633 \u0686\u0647 \u0627\u0635\u0648\u0644\u06cc \u0637\u0631\u0627\u062d\u06cc \u0645\u06cc\u200c\u0634\u0648\u062f\u061b \u0627\u0635\u0648\u0644\u06cc \u06a9\u0647 \u0628\u0639\u062f\u0627\u064b \u062a\u0645\u0627\u0645 \u062a\u0635\u0645\u06cc\u0645\u200c\u0647\u0627\u06cc \u0645\u062d\u0635\u0648\u0644\u060c \u0645\u0639\u0645\u0627\u0631\u06cc \u0646\u0631\u0645\u200c\u0627\u0641\u0632\u0627\u0631\u060c \u0645\u062f\u0644 \u062f\u0627\u062f\u0647\u060c \u0631\u0627\u0628\u0637 \u06a9\u0627\u0631\u0628\u0631\u06cc \u0648 \u062d\u062a\u06cc \u0645\u062f\u0644 \u06a9\u0633\u0628\u200c\u0648\u06a9\u0627\u0631 \u0628\u0627\u06cc\u062f \u0628\u0627 \u0622\u0646\u200c\u0647\u0627 \u0633\u0627\u0632\u06af\u0627\u0631 \u0628\u0627\u0634\u0646\u062f."
  },
