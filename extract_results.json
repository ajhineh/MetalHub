    "context": "\u067e\u0627\u06cc\u0627\u0646 \u0641\u0635\u0644 \u0686\u0647\u0627\u0631\u0645\n\u0645\u06cc\u200c\u062e\u0648\u0627\u0647\u0645 \u0627\u06cc\u0646 \u0641\u0635\u0644 \u0631\u0627 \u0628\u0627 \u062c\u0645\u0644\u0647\u200c\u0627\u06cc \u0628\u0647 \u067e\u0627\u06cc\u0627\u0646 \u0628\u0631\u0633\u0627\u0646\u0645 \u06a9\u0647 \u0628\u0647 \u0646\u0638\u0631 \u0645\u0646 \u0628\u0627\u06cc\u062f \u0628\u0647 \u06cc\u06a9\u06cc \u0627\u0632 \u0627\u0635\u0648\u0644 \u0645\u062f\u06cc\u0631\u06cc\u062a\u06cc MetalHub \u062a\u0628\u062f\u06cc\u0644 \u0634\u0648\u062f:\nA platform becomes sustainable not when it scales its software, but when it scales its ability to preserve its principles while growing.\n\u062a\u0631\u062c\u0645\u0647:\n\u06cc\u06a9 \u067e\u0644\u062a\u0641\u0631\u0645 \u0632\u0645\u0627\u0646\u06cc \u067e\u0627\u06cc\u062f\u0627\u0631 \u0645\u06cc\u200c\u0634\u0648\u062f \u06a9\u0647 \u0646\u0647 \u0641\u0642\u0637 \u0646\u0631\u0645\u200c\u0627\u0641\u0632\u0627\u0631 \u062e\u0648\u062f\u060c \u0628\u0644\u06a9\u0647 \u062a\u0648\u0627\u0646\u0627\u06cc\u06cc \u062d\u0641\u0638 \u0627\u0635\u0648\u0644\u0634 \u0631\u0627 \u0647\u0645\u200c\u0632\u0645\u0627\u0646 \u0628\u0627 \u0631\u0634\u062f \u0645\u0642\u06cc\u0627\u0633 \u062f\u0647\u062f."
  },
